# Nusxa ko‘chirib .env qiling (gitga qo‘shilmaydi)
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=o‘zgartiring-uzun-tasodifiy-qator

# Vergul bilan ajratilgan: api.example.com,127.0.0.1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Faqat DEBUG=false va HTTPS frontend uchun (CORS)
# CORS_ALLOWED_ORIGINS=https://app.example.com

# CSRF (admin / forma) — HTTPS originlar
# DJANGO_CSRF_TRUSTED_ORIGINS=https://app.example.com

# PostgreSQL (bo‘sh bo‘lsa SQLite)
# DATABASE_URL=postgres://user:pass@host:5432/medicentral
# DATABASE_SSL_REQUIRE=true
# DB_CONN_MAX_AGE=600

# SQLite fayl yo‘li (Docker volume uchun)
# DJANGO_SQLITE_PATH=/data/db.sqlite3

# Ko‘p pod / bir nechta worker: Redis majburiy
# REDIS_URL=redis://redis:6379/0

# Reverse proxy (nginx / ingress) orqasida HTTPS
# DJANGO_BEHIND_PROXY=true
# DJANGO_SECURE_SSL_REDIRECT=true

DJANGO_LOG_LEVEL=INFO

# Fon vitallar simulyatsiyasi (mock). Real HL7 / production uchun o'chiq.
MONITORING_SIMULATION_ENABLED=false

# HL7 MLLP (qurilmalar TCP orqali ulanadi; odatda 6006)
HL7_LISTEN_ENABLED=true
HL7_LISTEN_HOST=0.0.0.0
HL7_LISTEN_PORT=6006
# NAT: server TCP manbai lokal 192.168.x emas — bitta HL7 qurilmada avto hl7_peer_ip (true=standart)
HL7_NAT_SINGLE_DEVICE_FALLBACK=true
# Vitallar ajratilmasa — bir marta xom HL7 (PHI!) logini ko‘rsatish; keyin o‘chiring
# HL7_LOG_RAW_PREVIEW=true
# Qabul qilingan har ORU dan keyin MLLP ichida MSA|AA ACK (ba'zi monitorlar kutadi)
HL7_SEND_ACK=true
# TCP ochilgach serverdan birinchi MLLP (odatda o'chiq — ko'p K12 birinchi ORU ni o'zi yuboradi)
# HL7_SEND_CONNECT_HANDSHAKE=true
# Birinchi ORU kechiksa yoki hech kelmasa: cheksiz kutish (0); yoki masalan 300
HL7_RECV_TIMEOUT_SEC=0
# MSH topilmasa xom TCP qoldig'i (PHI!) — faqat diagnostika
# HL7_LOG_RAW_TCP_RECV=true

# Oxirgi ma'lumot shu vaqt ichida bo'lmasa "oqim yo'q" deb hisoblanadi (connection-check)
DEVICE_DATA_TIMEOUT_SECONDS=90

# Qurilma ekrani rasmini tahlil (Gemini Vision) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Ixtiyoriy: gemini-2.0-flash | gemini-1.5-flash
# GEMINI_VISION_MODEL=gemini-2.0-flash


[Unit]
Description=ClinicMonitoring Daphne (Django ASGI + Channels + HL7)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/clinicmonitoring/backend
EnvironmentFile=/opt/clinicmonitoring/backend/.env
ExecStart=/opt/clinicmonitoring/backend/.venv/bin/daphne -b 127.0.0.1 -p 8000 medicentral.asgi:application
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
